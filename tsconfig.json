{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "../../../src/std.ts": ["stubs/std.ts"],
      "../../../src/stores/map.ts": ["stubs/map-store.ts"],
      "../../../src/types.ts": ["stubs/types.ts"]
    }
  },
  "include": ["**/*.ts", "components/**/*.vue", "env.d.ts", "stubs/**/*.ts"],
  "exclude": ["node_modules", "cloudtak_plugin_docs/example.ts"]
}
